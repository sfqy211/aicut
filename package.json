{
  "name": "aicut",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:split": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:api": "pnpm --filter @aicut/api dev",
    "dev:web": "pnpm --filter @aicut/web dev",
    "dev:asr": "node scripts/dev-asr.js",
    "check:env": "node scripts/check-env.js",
    "build": "pnpm -r --filter \"./apps/**\" build",
    "typecheck": "pnpm -r --filter \"./apps/**\" typecheck",
    "lint": "pnpm -r --filter \"./apps/**\" lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
